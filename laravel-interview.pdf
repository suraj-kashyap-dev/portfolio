<footer class="border-t border-[#2a2a2a] py-10 text-center px-4">
  <div class="max-w-2xl mx-auto">
    <p class="text-gray-500 text-sm font-mono mb-2">Laravel Interview Kit — 5-6 Years Experience</p>
    <p class="text-gray-600 text-xs">Curated by a 15+ year interviewer perspective. 110+ questions across 8 categories.</p>
  </div>
</footer>

<script>
  let openedCards = new Set();
  let totalCards = document.querySelectorAll('.q-card').length;

  function toggle(header) {
    const card = header.closest('.q-card');
    const wasOpen = card.classList.contains('open');
    card.classList.toggle('open', !wasOpen);
    const num = card.querySelector('.q-num').textContent;
    if (!wasOpen) openedCards.add(num); else openedCards.delete(num);
    updateProgress();
  }

  function updateProgress() {
    const visible = [...document.querySelectorAll('.q-card')].filter(c => c.style.display !== 'none').length;
    const pct = visible > 0 ? Math.round((openedCards.size / totalCards) * 100) : 0;
    document.getElementById('progress-bar').style.width = pct + '%';
    document.getElementById('progress-text').textContent = `${openedCards.size} / ${totalCards} reviewed`;
  }

  let currentCat = 'all';

  function filterCat(cat) {
    currentCat = cat;
    document.querySelectorAll('.category-pill').forEach(p => p.classList.remove('active'));
    document.getElementById('pill-' + cat).classList.add('active');
    applyFilters();
  }

  function filterQuestions() {
    applyFilters();
  }

  function applyFilters() {
    const term = document.getElementById('search-input').value.toLowerCase().trim();
    const cards = document.querySelectorAll('.q-card');
    let visible = 0;
    cards.forEach(card => {
      const cat  = card.dataset.cat;
      const text = card.textContent.toLowerCase();
      const catMatch  = currentCat === 'all' || cat === currentCat;
      const termMatch = !term || text.includes(term);
      const show = catMatch && termMatch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    // Show/hide section headers
    document.querySelectorAll('.cat-section').forEach(section => {
      const anyVisible = [...section.querySelectorAll('.q-card')].some(c => c.style.display !== 'none');
      section.style.display = anyVisible ? '' : 'none';
    });

    document.getElementById('count-label').textContent = `${visible} shown`;
    document.getElementById('no-results').style.display = visible === 0 ? 'block' : 'none';
  }
</script>
</body>
</html>